# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib

# Build output
/bin/
/dist/
/chaperone
/chaperone-onboard

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
coverage.html

# Go workspace file
go.work
go.work.sum

# Dependency directories
vendor/

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Environment and secrets
.env
.env.local
*.pem
*.key
*.crt
*.csr
/credentials.json

# Generated test certificates
certs/

# Local configuration overrides
config.local.yaml

# Debug binaries
__debug_bin*

# Air live reload
tmp/

# Code review outputs (ephemeral)
.github/reviews/latest-review.md
.github/reviews/current-task.txt

# Benchmark artifacts (generated locally via make bench / make bench-save)
benchmark-baseline.txt
benchmark-current.txt
cpu.prof
mem.prof

# Load test results (generated by k6 handleSummary)
test/load/results/

# PID files for background processes
.target-server.pid
